# Optional: JSON user pools for multi-user testing
# K6_USERS_JSON=[{"username":"planner1","password":"secret"},{"username":"planner2","password":"secret"}]
# K6_APPROVERS_JSON=[{"username":"approver1","password":"secret"}]

# Optional k6 tuning for individual scenario runs
# VUS=10
# DURATION_SECONDS=60

# Optional approval behavior for progress-write-approve.js
# APPROVAL_MODE=approve
