{
  "plugin": {
    "pluginKey": "sample-project-insights",
    "name": "Sample Project Insights",
    "version": "1.0.0",
    "author": "SETU",
    "description": "Reference plugin that adds a project insights workspace.",
    "appCompatibility": "^0.0.1",
    "capabilities": [
      "menus",
      "pages",
      "widgets",
      "reports",
      "workflows",
      "settings"
    ],
    "installPolicy": {
      "approvalRequired": true
    },
    "uninstallPolicy": {
      "mode": "ARCHIVE",
      "requiresDisableFirst": true
    }
  },
  "permissions": [
    {
      "code": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "name": "View Sample Project Insights",
      "moduleName": "PLUGIN",
      "scopeLevel": "PROJECT",
      "actionType": "READ"
    }
  ],
  "menus": [
    {
      "menuKey": "sample-project-insights",
      "label": "Project Insights",
      "location": "PROJECT",
      "pageKey": "insights-table",
      "permissionCode": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "requiresProject": true,
      "sortOrder": 10
    }
  ],
  "pages": [
    {
      "pageKey": "insights-table",
      "title": "Insights Table",
      "rendererType": "hostTablePage",
      "permissionCode": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "config": {
        "columns": [
          {
            "key": "metric",
            "label": "Metric"
          },
          {
            "key": "value",
            "label": "Value"
          }
        ],
        "staticRows": [
          {
            "metric": "Open RFIs",
            "value": 12
          },
          {
            "metric": "Pending Stage Approvals",
            "value": 4
          },
          {
            "metric": "Delayed Issues",
            "value": 3
          }
        ]
      }
    },
    {
      "pageKey": "insights-report",
      "title": "Insights Report",
      "rendererType": "hostReportAction",
      "permissionCode": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "config": {
        "reportKey": "project-insights-summary"
      }
    }
  ],
  "widgets": [
    {
      "widgetKey": "project-insights-kpi",
      "title": "Project Insights KPI",
      "widgetType": "kpi",
      "permissionCode": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "config": {
        "summary": "Reference KPI widget for plugin developers."
      }
    }
  ],
  "reports": [
    {
      "reportKey": "project-insights-summary",
      "title": "Project Insights Summary",
      "permissionCode": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "exportTypes": [
        "VIEW",
        "CSV"
      ],
      "config": {
        "columns": [
          {
            "key": "category",
            "label": "Category"
          },
          {
            "key": "count",
            "label": "Count"
          }
        ],
        "previewRows": [
          {
            "category": "RFIs",
            "count": 12
          },
          {
            "category": "Stage Approvals",
            "count": 4
          },
          {
            "category": "Issues",
            "count": 3
          }
        ]
      }
    }
  ],
  "workflows": [
    {
      "workflowKey": "sample-project-insights-approval",
      "moduleCode": "PLANNING",
      "processCode": "PLUGIN_SAMPLE_PROJECT_INSIGHTS_APPROVAL",
      "permissionCode": "PLUGIN.SAMPLE-PROJECT-INSIGHTS.VIEW",
      "isActive": true,
      "config": {
        "description": "Reference plugin workflow metadata."
      }
    }
  ],
  "settingsSchema": [
    {
      "settingKey": "highlightThreshold",
      "label": "Highlight Threshold",
      "fieldType": "number",
      "required": false,
      "defaultValue": 5
    }
  ]
}