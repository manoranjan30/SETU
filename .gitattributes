# Normalize all text files to LF on commit/checkout.
# Prevents CRLF/LF diff noise on the Linux server when files are pushed from Windows.
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
