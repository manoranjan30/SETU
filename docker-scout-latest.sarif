                "markdown": "> \n\n|                                                                             |\n|Package         pkg:apk/alpine/zlib@1.3.1-r2?os_name=alpine&os_version=3.23  |\n|Affected range  <1.3.2-r0                                                    |\n|Fixed version   1.3.2-r0                                                     |\n"
              },
